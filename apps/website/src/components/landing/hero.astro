---
import HeroPlayground from '../client/hero-playground.svelte'

interface Props {
  docsLink?: string
}

const { docsLink = '/docs' } = Astro.props as Props

const stats = [
  { num: 11, label: 'Themes' },
  { num: 7, label: 'Frameworks' },
  { num: 0, label: 'Dependencies' },
]
---

<section class="relative overflow-hidden">
  <div class="mx-auto max-w-[1280px] px-8 pt-20 pb-30">
    <div
      class="grid grid-cols-1 items-center gap-14 lg:grid-cols-[minmax(0,0.75fr)_minmax(0,1fr)] lg:gap-16"
    >
      <div class="min-w-0">
        <h1
          class="mb-7 font-display text-[clamp(56px,7.2vw,104px)] leading-[0.96] font-[380] tracking-[-0.035em] [&_.soft]:font-normal [&_.soft]:text-ink-3"
        >
          Avatars that <span class="soft">feel</span><br />
          like people.
        </h1>

        <p
          class="mt-6 max-w-[56ch] font-body text-[18px] leading-[1.55] text-ink-2"
        >
          A typed, SSR-first avatar primitive for the web — seven frameworks,
          eleven themes, zero dependencies. Compose by hand or let the
          predictor draft from a photo.
        </p>

        <div class="mt-9 flex flex-wrap items-center gap-3">
          <a
            href={docsLink}
            class="inline-flex items-center gap-2 rounded-lg border border-ink bg-ink px-4 py-2.5 text-sm font-medium whitespace-nowrap text-paper transition hover:border-white hover:bg-white active:translate-y-px"
          >
            <span>Get started</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14" />
              <path d="m13 6 6 6-6 6" />
            </svg>
          </a>
          <button
            type="button"
            data-install-copy
            class="inline-flex cursor-pointer items-center gap-2 rounded-lg border border-line-2 bg-paper-3 px-4 py-2.5 text-sm font-medium whitespace-nowrap text-ink transition hover:border-line-strong hover:bg-paper-card active:translate-y-px"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="m4 17 6-6-6-6" />
              <path d="M12 19h8" />
            </svg>
            <code class="font-code text-[12px]">npm i @avatune/react</code>
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="9" y="9" width="13" height="13" rx="2" />
              <path d="M5 15V5a2 2 0 0 1 2-2h10" />
            </svg>
          </button>
        </div>

        <div
          class="mt-12 flex items-stretch gap-0 border-t border-line pt-6"
        >
          {stats.map((stat, idx) => (
            <div
              class:list={[
                'pr-8',
                idx < stats.length - 1 ? 'mr-8 border-r border-line' : '',
              ]}
            >
              <div
                class="font-display text-[36px] leading-none font-normal tracking-[-0.02em]"
              >
                {stat.num}
              </div>
              <div
                class="mt-2 font-code text-[11px] tracking-[0.16em] uppercase text-ink-3"
              >
                {stat.label}
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="min-w-0">
        <HeroPlayground client:only="svelte" />
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLButtonElement>('[data-install-copy]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText('npm i @avatune/react')
        window.dispatchEvent(
          new CustomEvent('avatune:toast', { detail: 'Copied npm i @avatune/react' })
        )
      } catch {
        /* clipboard blocked — no-op */
      }
    })
  })
</script>
