---
import Toast from '../components/client/toast.svelte'
import Footer from '../components/landing/footer.astro'
import Frameworks from '../components/landing/frameworks.astro'
import Hero from '../components/landing/hero.astro'
import Nav from '../components/landing/nav.astro'
import Predictor from '../components/landing/predictor.astro'
import WhyGrid from '../components/landing/why-grid.astro'
import '../styles/global.css'
import '../styles/landing.css'
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Avatune — Avatars that feel like people</title>
    <meta
      name="description"
      content="A typed, SSR-first avatar primitive for the web — seven frameworks, eleven themes, zero dependencies. Compose by hand or let the predictor draft from a photo."
    />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Newsreader:opsz,wght@6..72,300..700&family=Geist:wght@300..700&family=Geist+Mono:wght@400..600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body
    class="bg-paper text-ink font-body text-[15px] leading-[1.55] antialiased [text-rendering:optimizeLegibility] [font-feature-settings:'ss01','ss02','cv11'] [&_a]:no-underline"
  >
    <Nav />
    <Hero docsLink="/docs" />
    <WhyGrid />
    <Frameworks />
    <Predictor />
    <Footer />
    <Toast client:only="svelte" />
  </body>
</html>
