  "dependencies": {
    "@avatune/types": "workspace:*",
    "@avatune/utils": "workspace:*"
  },
  "devDependencies": {
    "@rslib/core": "^0.16.1",
    "@types/node": "^22.18.12",
    "typescript": "^5.9.3",
    "@avatune/typescript-config": "workspace:*"
  },
  "license": "MIT"
}
