  },
  "devDependencies": {
    "@avatune/typescript-config": "workspace:*",
    "@rsbuild/plugin-svelte": "^1.0.10",
    "@rslib/core": "^0.16.1",
    "@types/node": "^22.18.12",
    "svelte": "^5.0.0",
    "typescript": "^5.9.3"
